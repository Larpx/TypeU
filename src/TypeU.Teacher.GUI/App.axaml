<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Larpx.PersonalTools.TypeU.Teacher.GUI.ViewModels"
             xmlns:pages="using:Larpx.PersonalTools.TypeU.Teacher.GUI.ViewModels.Pages"
             xmlns:views="using:Larpx.PersonalTools.TypeU.Teacher.GUI.Views"
             xmlns:pagesViews="using:Larpx.PersonalTools.TypeU.Teacher.GUI.Views.Pages"
             x:Class="Larpx.PersonalTools.TypeU.Teacher.GUI.App"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <DataTemplate DataType="{x:Type pages:DashboardPageViewModel}">
            <pagesViews:DashboardPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pages:QuestionPageViewModel}">
            <pagesViews:QuestionPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pages:ExamControlPageViewModel}">
            <pagesViews:ExamControlPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pages:GradePageViewModel}">
            <pagesViews:GradePage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pages:DeviceBindingPageViewModel}">
            <pagesViews:DeviceBindingPage />
        </DataTemplate>
        <DataTemplate DataType="{x:Type pages:LanScanPageViewModel}">
            <pagesViews:LanScanPage />
        </DataTemplate>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        <Style Selector="Border.card">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderBrush" Value="#e2e8f0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{DynamicResource SystemRegionBrush}"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style Selector="TextBlock.title">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="600"/>
        </Style>
        <Style Selector="TextBlock.subtitle">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="600"/>
        </Style>
        <Style Selector="TextBlock.caption">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Opacity" Value="0.7"/>
        </Style>
        <Style Selector="Button.nav">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style Selector="Button.nav.active">
            <Setter Property="Background" Value="{DynamicResource SystemAccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Border.status-idle">
            <Setter Property="Background" Value="#94a3b8"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.status-examining">
            <Setter Property="Background" Value="#22c55e"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.status-submitted">
            <Setter Property="Background" Value="#3b82f6"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.status-anomaly">
            <Setter Property="Background" Value="#ef4444"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Border.status-offline">
            <Setter Property="Background" Value="#6b7280"/>
            <Setter Property="Width" Value="12"/>
            <Setter Property="Height" Value="12"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
    </Application.Styles>
</Application>
